# Copiar este archivo como .env y ajustar los valores según el entorno.
# Nunca commitear el archivo .env con credenciales reales.

# Entorno de ejecución: development | staging | production
APP_ENV=development

# Configuración de la aplicación
APP_NAME=Asistente de Inteligencia Empresarial Olnatura
APP_VERSION=0.1.0
DEBUG=true

# Servidor
HOST=0.0.0.0
PORT=8000

# Logging: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Base de datos PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
DATABASE_URL=postgresql://postgres:Olnatura.25@localhost:5432/olnatura_ai

# Configuración del pool de conexiones SQLAlchemy
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_PRE_PING=true

# Dynamics 365 Finance & Operations (OData)
D365_BASE_URL=https://your-env.operations.dynamics.com/data
D365_TENANT_ID=your-azure-tenant-id
D365_CLIENT_ID=your-app-client-id
D365_CLIENT_SECRET=your-app-client-secret
# Opcionales: se derivan automáticamente si se dejan vacíos
D365_TOKEN_URL=
D365_OAUTH_SCOPE=
D365_HEALTH_ENTITY=Companies
D365_REQUEST_TIMEOUT=30.0
D365_CLIENTES_ENTITY=CustomersV3
D365_VENTAS_ENTITY=SalesOrderHeadersV2

# ETL — sincronización Dynamics → PostgreSQL
ETL_PAGE_SIZE=100
ETL_MAX_RETRIES=3
ETL_RETRY_BASE_DELAY=1.0
SYNC_CLIENTES_MAX_RECORDS=100
SYNC_VENTAS_MAX_RECORDS=100
D365_VENTAS_ENTITY_LABEL=D365SalesOrderHeaders

# Ollama — inferencia LLM local
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_REQUEST_TIMEOUT=120.0

# RAG — LangChain + ChromaDB
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=olnatura_documents
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=4
