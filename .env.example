# Copiar este archivo como .env y ajustar los valores según el entorno.
# Nunca commitear el archivo .env con credenciales reales.

# Entorno de ejecución: development | staging | production
APP_ENV=development

# Configuración de la aplicación
APP_NAME=Asistente de Inteligencia Empresarial Olnatura
APP_VERSION=0.1.0
DEBUG=true

# Servidor
HOST=0.0.0.0
PORT=8000

# Logging: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Base de datos PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/olnatura_ai

# Configuración del pool de conexiones SQLAlchemy
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_PRE_PING=true
